FLASK_URL=http://localhost:5001
# Bearer token gating all admin/maintenance endpoints (backend + blockchain).
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=replace-with-a-local-development-token
# Transactional email (optional — leave unset to disable outbound email).
# VORLIQ_EMAIL_API_URL=https://api.resend.com/emails
# VORLIQ_EMAIL_API_KEY=replace-with-provider-key
# VORLIQ_EMAIL_FROM=noreply@example.org
