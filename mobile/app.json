{
  "expo": {
    "name": "Vorliq",
    "slug": "vorliq",
    "version": "1.0.0",
    "description": "Experimental open-source community blockchain software with the VLQ coin",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "primaryColor": "#6c63ff",
    "newArchEnabled": true,
    "plugins": [
      "expo-notifications"
    ],
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vorliq.app"
    },
    "android": {
      "package": "com.vorliq.app",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0f0f1a"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.png"
    }
  }
}
